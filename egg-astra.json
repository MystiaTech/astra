{
    "_comment": "Astra Tarot Bot Egg for Pterodactyl Panel",
    "meta": {
        "version": "PTDL_v2",
        "update_url": null
    },
    "exported_at": "2026-04-08",
    "name": "Astra Tarot Bot",
    "author": "mystiatech@fullmooncyberworks.com",
    "description": "Discord tarot reading bot with dynamic themes and hot-reload",
    "features": null,
    "docker_images": {
        "ghcr.io\/mystiatech\/astra-bot:latest": "ghcr.io\/mystiatech\/astra-bot:latest",
        "python:3.10-slim": "python:3.10-slim"
    },
    "file_denylist": "",
    "startup": "python -m astra",
    "config": {
        "files": "{\n    \".env\": {\n        \"parser\": \"properties\",\n        \"find\": {\n            \"DISCORD_TOKEN\": \"{{server.build.env.DISCORD_TOKEN}}\"\n        }\n    }\n}",
        "startup": "{\n    \"done\": \"Synced.*slash commands\"\n}",
        "logs": "{}",
        "stop": "^C"
    },
    "scripts": {
        "installation": {
            "script": "#!/bin\/bash\n# Astra Installation Script for Pterodactyl\n\ncd \/home\/container\n\n# Clone repository\necho \"Cloning Astra repository...\"\nif [ -d .git ]; then\n    git pull\nelse\n    git clone {{REPO_URL}} .\nfi\n\n# Install dependencies\necho \"Installing dependencies...\"\npip install --user --no-cache-dir -e .\n\n# Create necessary directories\nmkdir -p data themes\n\necho \"Installation complete!\"",
            "container": "python:3.10-slim",
            "entrypoint": "bash"
        }
    },
    "variables": [
        {
            "name": "Repository URL",
            "description": "Git repository URL for Astra",
            "env_variable": "REPO_URL",
            "default_value": "https:\/\/giteas.fullmooncyberworks.com\/mystiatech\/Astra.git",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string",
            "field_type": "text"
        },
        {
            "name": "Discord Token",
            "description": "Your Discord bot token from the Developer Portal",
            "env_variable": "DISCORD_TOKEN",
            "default_value": "",
            "user_viewable": false,
            "user_editable": true,
            "rules": "required|string",
            "field_type": "text"
        },
        {
            "name": "Log Level",
            "description": "Logging level for the bot",
            "env_variable": "LOG_LEVEL",
            "default_value": "INFO",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|in:DEBUG,INFO,WARNING,ERROR",
            "field_type": "text"
        },
        {
            "name": "Auto Update",
            "description": "Automatically pull updates on server start",
            "env_variable": "AUTO_UPDATE",
            "default_value": "0",
            "user_viewable": true,
            "user_editable": true,
            "rules": "boolean",
            "field_type": "text"
        }
    ]
}
